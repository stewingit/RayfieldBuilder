return function(Data)
    -- 1. Close existing preview
    if getgenv().RayfieldPreview then 
        getgenv().RayfieldPreview:Destroy() 
    end

    -- 2. Load Rayfield
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    
    -- 3. Create the Window from Data
    local Window = Rayfield:CreateWindow({
        Name = Data.Window.Name .. " (PREVIEW)",
        LoadingTitle = Data.Window.LoadingTitle,
        LoadingSubtitle = Data.Window.LoadingSubtitle,
        Icon = Data.Window.Icon,
        ConfigurationSaving = {Enabled = false}
    })

    -- 4. Create the Tabs and Elements from Data
    for _, tabData in ipairs(Data.Tabs) do
        local Tab = Window:CreateTab(tabData.Name, tabData.Icon or "home")
        for _, el in ipairs(tabData.Elements) do
            if el.Type == "Button" then
                Tab:CreateButton({Name = el.Name, Callback = function() end})
            elseif el.Type == "Toggle" then
                Tab:CreateToggle({Name = el.Name, CurrentValue = false, Callback = function() end})
            elseif el.Type == "Slider" then
                Tab:CreateSlider({Name = el.Name, Range = {0, 100}, Increment = 1, CurrentValue = 10, Callback = function() end})
            elseif el.Type == "Section" then
                Tab:CreateSection(el.Name)
            end
        end
    end
    
    -- Store reference to destroy later
    getgenv().RayfieldPreview = Rayfield
end
